# ═══════════════════════════════════════════════════════════════════════
#  PRODUCTION ENV — Copy to .env.production and fill in values
# ═══════════════════════════════════════════════════════════════════════

# ── Domain ────────────────────────────────────────────────────────────
DOMAIN=app.atluriin.com

# ── PostgreSQL (local, inside Docker) ─────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=linkedin_ai

# ── Redis (local, inside Docker) ──────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Backend Workers ───────────────────────────────────────────────────
BACKEND_WORKERS=4

# ── CORS (frontend domain) ───────────────────────────────────────────
CORS_ALLOW_ORIGINS=https://app.atluriin.com

# ── LLM API Keys (at least OPENAI required) ──────────────────────────
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4.1-mini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Deepgram (speech-to-text) ────────────────────────────────────────
DEEPGRAM_API_KEY=

# ── Supabase Auth (if using Supabase for auth) ───────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# ── For testing without Supabase auth ─────────────────────────────────
ALLOW_UNVERIFIED_JWT_DEV=false

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=300
