{
  "name": "atluriin-desktop-practice",
  "private": true,
  "version": "0.3.1",
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build": "tsc -p tsconfig.json && cpx \"src/renderer/index.html\" dist/renderer",
    "dev": "npm run build && electron .",
    "dev:watch": "concurrently -k \"tsc -p tsconfig.json -w\" \"electron .\"",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:hardened": "npm run build && electron-builder --win --publish never",
    "sign:win": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\sign-windows-installer.ps1",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "ws": "^8.18.1"
  },
  "optionalDependencies": {
    "win-audio-capture": "^1.0.1"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.2",
    "cpx": "^1.5.0",
    "electron": "^35.7.4",
    "electron-builder": "^24.13.3",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.atluriin.ai.desktop",
    "productName": "AtluriIn AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "executableName": "AtluriInAI",
      "artifactName": "AtluriIn-AI-${version}-Setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "executableName": "AtluriInAI",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
