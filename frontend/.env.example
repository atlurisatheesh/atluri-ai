# Frontend environment variables
# Copy to .env.local and fill in values

# Backend API URL (set after deploying backend)
NEXT_PUBLIC_API_URL=http://localhost:9010

# WebSocket URL (same as API URL but ws://)
NEXT_PUBLIC_WS_URL=ws://localhost:9010

# Supabase (optional — app works without it using local auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# E2E testing bypass (set to "true" to skip auth)
NEXT_PUBLIC_E2E_BYPASS_AUTH=false
